{
	"name": "voice-feedback",
	"version": "1.0.0",
	"description": "A powerful 360 panorama viewer with Gutenberg block and Elementor addon support",
	"author": "Tanin Rahman",
	"license": "GPL-2.0-or-later",
	"scripts": {
		"lint": "eslint src",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"format": "wp-scripts format",
		"start": "wp-scripts start --webpack-copy-php",
		"build": "wp-scripts build --webpack-copy-php",
		"i18n-pot": "wp i18n make-pot . languages/voice-feedback.pot --exclude=\"build,node_modules,vendor\" --domain=\"voice-feedback\" && cp ./languages/voice-feedback.pot ./languages/voice-feedback-en_US.po",
		"i18n-json": "wp i18n make-json languages/ --no-purge",
		"i18n-mo": "wp i18n make-mo languages/",
		"i18n": "npm run i18n-pot && npm run i18n-json && npm run i18n-mo",
		"plugin-zip": "wp-scripts plugin-zip",
		"zip": "zip -r voice-feedback.zip build includes languages vendor assets readme.txt voice-feedback.php",
		"bundle": "npm run lint && npm run build && npm run i18n && find . -name '.DS_Store' -delete && npm run zip"
	},
	"files": [
		"assets",
		"build",
		"includes",
		"languages",
		"vendor",
		"voice-feedback.php",
		"readme.txt"
	],
	"devDependencies": {
		"@wordpress/scripts": "^26.0.0",
		"eslint-webpack-plugin": "^4.2.0",
		"gulp": "^5.0.0",
		"gulp-zip": "^6.0.0"
	},
	"dependencies": {
		"@fancyapps/ui": "^6.0.5",
		"@fortawesome/free-solid-svg-icons": "^6.7.2",
		"@fortawesome/react-fontawesome": "^0.2.2",
		"@gsap/react": "^2.1.2",
		"immer": "^10.1.1",
		"leaflet": "^1.9.4",
		"leaflet-control-geocoder": "^3.2.0",
		"leaflet-fullscreen": "^1.0.2",
		"leaflet.locatecontrol": "^0.84.2",
		"lodash": "^4.17.21",
		"plyr-react": "^5.3.0",
		"react-hot-toast": "^2.5.2",
		"react-inlinesvg": "^4.2.0",
		"react-leaflet": "^5.0.0",
		"react-responsive-masonry": "^2.7.1",
		"react-router-dom": "^7.6.2",
		"react-video-thumbnail": "^0.1.3",
		"react-voice-visualizer": "^2.0.8",
		"sanitize-html": "^2.17.0",
		"select-pure": "^2.1.4",
		"swiper": "^11.2.8",
		"typed.js": "^2.1.0",
		"wavesurfer.js": "^7.9.5"
	}
}
